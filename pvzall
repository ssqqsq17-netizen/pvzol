# 获取cookies程序
def Get_cookie(username, password, zone_id):
    # 初始化会话
    session = requests.Session()

    # 添加请求头，模拟浏览器
    headers = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
        'Accept-Language': 'zh-CN,zh;q=0.9,en;q=0.8',
        'Referer': f'http://www.youkia.com/index.php/pvz/s{zone_id}',
        'Upgrade-Insecure-Requests': '1',
        'X-Requested-With': 'XMLHttpRequest',
        'Connection': 'keep-alive',
    }
    session.headers.update(headers)

    # 访问主页获取初始cookie
    home_response = session.get("http://www.youkia.com/")

    # 步骤1: 登录请求
    timestamp = int(time.time() * 1000)
    login_url = f"http://www.youkia.com/index.php/logins/login?jsoncallback=jsonp{timestamp}&_={timestamp + 14000}&account={username}&password={password}"

    # 添加额外的请求头
    login_headers = headers.copy()
    login_headers['Accept'] = 'application/json, text/javascript, */*; q=0.01'
    login_headers['Content-Type'] = 'application/x-www-form-urlencoded; charset=UTF-8'

    # 发送登录请求
    response = session.get(login_url, headers=login_headers)

    return_response = parse_jsonp(response.text)

    if '密码错误' in str(return_response):
        return "密码错误"

    # 步骤2: 解析JSONP响应
    jsonp_content = response.text
    json_content = jsonp_content[jsonp_content.find("{"):jsonp_content.rfind("}") + 1]

    try:
        json_data = json.loads(json_content)
        account_name = json_data.get("nickname", "")
        time_str = str(json_data.get("time", 0))
        sign = json_data.get("sign", "")

        # 确保获取到正确的sign值
        if not sign and "sign" in json_data:
            sign = json_data["sign"]

        # 步骤3: 访问入口页面
        entrance_url = f"http://www.youkia.com/index.php/entrance/entrance?url=http%3A%2F%2Fpvz.youkia.com%2Findex.php%2Findex%2Fgame%3Fs%3Ds{zone_id}&gid=2&sid={zone_id}"
        entrance_response = session.get(entrance_url)

        # 步骤4: 保存第一次跳转后的cookies
        first_redirect_cookies = session.cookies.get_dict()

        # 步骤5: 访问区服页面
        zone_page_url = f"http://www.youkia.com/index.php/pvz/s{zone_id}"
        zone_page_response = session.get(zone_page_url)

        # 步骤6: 从区服页面提取iframe URL
        iframe_patterns = [
            r'src=[\'"](.*?)[\'"]',
            r'iframe.*?src=[\'"](.*?)[\'"]',
            r'<iframe\s+[^>]*src=[\'"](.*?)[\'"]',
            r'<iframe[^>]*src="([^"]+)"',
            r'<iframe[^>]*src=\'([^\']+)\'',
            r'<iframe[^>]*src="([^"]+?\.php[^"]*)"',
            r'<iframe[^>]*src="([^"]+?\.html[^"]*)"',
        ]

        iframe_url = None
        for pattern in iframe_patterns:
            matches = re.findall(pattern, zone_page_response.text)

            for match in matches:
                if not match.startswith(('http://', 'https://', '/')):
                    continue

                if match.endswith('.js'):
                    continue

                if any(exclude in match for exclude in ['activationstatus', 'ad', 'advertisement', 'banner']):
                    continue

                iframe_url = match
                break

            if iframe_url:
                break

        # 步骤7: 处理iframe URL或使用备用方法
        if iframe_url:
            # 确保URL是绝对路径
            if iframe_url.startswith('/'):
                iframe_url = f"http://www.youkia.com{iframe_url}"

            # 访问iframe URL获取cookies
            final_response = session.get(iframe_url)
        else:
            # 构造游戏URL
            encoded_nickname = urllib.parse.quote(account_name)
            game_url = f"http://s{zone_id}.youkia.pvz.youkia.com/pvz/index.php?user_id={account_name}&nickname={account_name}&domain=youkia.com&sig={sign}&time={time_str}&invite_user_id=0"

            # 创建一个新的会话用于此请求
            game_session = requests.Session()
            game_session.headers.update(headers)

            # 设置第一次跳转后的cookies
            for cookie_name, cookie_value in first_redirect_cookies.items():
                game_session.cookies.set(cookie_name, cookie_value)

            # 访问游戏URL
            game_response = game_session.get(
                game_url,
                allow_redirects=True,
                timeout=30,
                headers={
                    'Referer': zone_page_url,
                    'X-Requested-With': 'XMLHttpRequest'
                }
            )

            # 合并新获取的cookies到主会话
            for cookie_name, cookie_value in game_session.cookies.get_dict().items():
                session.cookies.set(cookie_name, cookie_value)

            final_response = game_response

        # 步骤8: 模拟易语言中的"区号网址"访问
        zone_url_pattern = r'<iframe[^>]*src="([^"]+?\.php[^"]*)"'
        zone_url_match = re.search(zone_url_pattern, zone_page_response.text)

        if zone_url_match:
            zone_game_url = zone_url_match.group(1)

            # 确保URL是绝对路径
            if zone_game_url.startswith('/'):
                zone_game_url = f"http://www.youkia.com{zone_game_url}"
        else:
            # 使用构造的游戏URL作为区号网址
            zone_game_url = game_url

        # 使用第一次跳转后的cookies访问游戏URL
        try:
            # 创建一个新的会话用于此请求
            zone_session = requests.Session()
            zone_session.headers.update(headers)

