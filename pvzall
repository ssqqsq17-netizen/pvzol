# 查看单层僵尸狩猎场
def TheLookPublic(daqu, ck, public_id, floors):

    while True:
        if int(daqu) > 12:
            public_url = f'http://s{daqu}.youkia.pvz.youkia.com/pvz/index.php/cave/index/id/{public_id}/type/public_{floors}/sig'
        else:
            public_url = f'http://pvz-s{daqu}.youkia.com/pvz/index.php/cave/index/id/{public_id}/type/public_{floors}/sig'
        user_look_public = GET_TXT(public_url, daqu, ck)
        if "success" in str(user_look_public):
            break
        if "此账号" in str(user_look_public):
            return "跳过"

    root = ET.fromstring(user_look_public[1])  # 解析XML文本
    hunting = root.find('hunting')  # 定位到<hunting>标签
    all_public = []

    if hunting is not None:
        h_list = hunting.findall('h')  # 找到所有的<h>标签（每个<h>标签代表一个记录）
        for h in h_list:
            oi_val = h.find('oi').text if h.find('oi') is not None else ''  # 洞口编号
            if oi_val != '':  # 判断洞口有没有开启
                ct_val = h.find('ct').text if h.find('ct') is not None else ''  # 植物剩余的冷却时间
                na_val = h.find('na').text if h.find('na') is not None else ''  # 洞口的名字
                all_public.append([oi_val, ct_val, na_val])

        return all_public

