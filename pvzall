    for index_state in list_state:
        start, end = index_state
        found = False  # 标记是否找到已存在的任务

        # 倒序检查任务存在性
        for i in range(end, start - 1, -1):
            exists = any(sub_list[0] == str(i) for sub_list in user_reward)

            if exists:
                found = True
                # 收集可领取的任务编号（start到i-1）
                receivable_tasks.extend(range(start, i))
