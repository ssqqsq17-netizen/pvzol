    url = f"http://www.youkia.com/index.php/homef/pop?type=footprint&userid={task_id}"

    # 发送HTTP请求获取网页内容

    try:

        # 发送HTTP请求获取网页内容
        response = requests.get(url, timeout=10)
        response.encoding = 'utf-8'  # 确保中文字符能正确显示，根据网页编码调整

        # 使用ET.fromstring解析网页内容
        # 由于ET不直接支持HTML解析，这里需要先将HTML内容包装在一个根元素中
        html_content = '<root>' + response.text + '</root>'
        root = ET.fromstring(html_content)

        # 查找id为'footprint'的ul标签
        ul_tag = root.find('.//ul[@id="footprint"]')
        # 在ul标签中查找所有的li标签
        if ul_tag is not None:
            li_tags = ul_tag.findall('li')
            if li_tags:
                first_li = li_tags[0]
                time_strong_tag = first_li.find('strong')
                if time_strong_tag is not None:
                    time_text = time_strong_tag.text.strip()  # 获取时间文本并去除两端空白
                    return time_text
                else:
                    print("未找到时间信息")
            else:
                print("未找到<li>标签")
        else:
            print("未找到<ul id='footprint'>标签")

    except requests.exceptions.Timeout:
        print("请求超时（超过10秒）")
        return "跳过"
    except requests.exceptions.RequestException as e:
        print("其他请求异常：", e)
        return "跳过"

    except ConnectionError as e:
        print("其他请求异常：", e)
        return "跳过"
    except (requests.exceptions.ConnectionError, UnboundLocalError, requests.exceptions.HTTPError) as e:
        print("其他请求异常：", e)
        return "跳过"

