# 等级计算机
def level_computer(current_level, target_level, daily_exp):

    # 检查输入是否为空
    if not current_level or not target_level or not daily_exp:
        return add_text_tail("所有输入框不能为空！")

    # 检查输入是否为数字
    if not current_level.isdigit() or not target_level.isdigit() or not daily_exp.isdigit():
        return add_text_tail("输入必须为数字！")

    # 转换为整数
    current_level = int(current_level)
    target_level = int(target_level)
    daily_exp = int(daily_exp)

    # 检查等级范围
    if current_level < 41:
        return add_text_tail("当前等级必须大于或等于41级！")
    if target_level > 125:
        return add_text_tail("目标等级不能超过125级！")
    if target_level <= current_level:
        return add_text_tail("目标等级必须大于当前等级！")

    # 等级列表
    Level_List = [1000] * 41
    Level_List += [985, 1030, 1075, 1120, 1170, 1220, 1270, 1320, 1370, 1425, 1480, 1535, 1590, 1645, 1700, 1765, 1800, 1801, 1802, 1803, 1804, 1805, 1806, 1807, 1808, 1809, 1810, 1811, 1812, 1813, 1814, 1815, 1816, 1817, 1818, 1819, 1820, 1821, 1822, 1823, 1824, 1825, 1826, 1827, 1828, 1829, 1830, 1831, 1832, 1833, 1834, 1835, 1836, 1837, 1838, 1839, 1840, 1841, 1842, 2142, 2642, 3342, 4242, 5342, 6642, 8142, 9742, 11442, 13242, 15000, 16500, 18000, 19500, 21000, 22500, 24000, 25500, 27000, 28500, 30000, 31500, 33000, 34500, 36000]

    # 计算所需经验
    total_exp = sum(Level_List[current_level - 1:target_level - 1])
    required_days = total_exp // daily_exp
    if total_exp % daily_exp != 0:
        required_days += 1

    # 返回结果
    return add_text_tail(str(required_days) + "天")

