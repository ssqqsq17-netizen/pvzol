def extract_face_url(html_text):
    """从HTML中提取头像URL"""
    # 匹配模式: /swf/tou.swf?path=http://www.youkia.info/attach/picture/.../face128.jpg?...
    pattern = r'/swf/tou\.swf\?path=(http://www\.youkia\.info/attach/picture/\d+/\d+/face128\.jpg\?\d+)'
    match = re.search(pattern, html_text)
    if match:
        return match.group(1)
    return None

# 获取头像更换链接
def get_face_url(username, password):

    session = requests.Session()

    # 添加请求头，模拟浏览器
    headers = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
        'Accept-Language': 'zh-CN,zh;q=0.9,en;q=0.8',
        'Referer': f'http://www.youkia.com/index.php/pvz/s33',
        'Upgrade-Insecure-Requests': '1',
        'X-Requested-With': 'XMLHttpRequest',
        'Connection': 'keep-alive',
    }
    session.headers.update(headers)

    # 访问主页获取初始cookie
    home_response = session.get("http://www.youkia.com/")

    # 步骤1: 登录请求
    timestamp = int(time.time() * 1000)
    login_url = f"http://www.youkia.com/index.php/logins/login?jsoncallback=jsonp{timestamp}&_={timestamp + 14000}&account={username}&password={password}"

    # 添加额外的请求头
    login_headers = headers.copy()
    login_headers['Accept'] = 'application/json, text/javascript, */*; q=0.01'
    login_headers['Content-Type'] = 'application/x-www-form-urlencoded; charset=UTF-8'

    # 发送登录请求
    response = session.get(login_url, headers=login_headers)

    return_response = parse_jsonp(response.text)

    if '密码错误' in str(return_response):
        return "密码错误", {}

    # 步骤2: 解析JSONP响应
    jsonp_content = response.text
    json_content = jsonp_content[jsonp_content.find("{"):jsonp_content.rfind("}") + 1]


    json_data = json.loads(json_content)
    account_name = json_data.get("nickname", "")
    time_str = str(json_data.get("time", 0))
    sign = json_data.get("sign", "")

    # 确保获取到正确的sign值
    if not sign and "sign" in json_data:
        sign = json_data["sign"]

    # 步骤3: 访问入口页面
    entrance_url = f"http://www.youkia.com/index.php/home/event"
    entrance_response = session.get(entrance_url)
    html_text = entrance_response.text

    # 提取头像URL
    face_url = extract_face_url(html_text)
    cookies = session.cookies.get_dict()

    if face_url:
        print(f"找到头像URL:http://www.youkia.com/swf/tou.swf?path={face_url}")
        # 返回SWF地址
        return f"http://www.youkia.com/swf/tou.swf?path={face_url}", cookies
    else:
        print("未找到头像URL")
        return None, {}
