def parse_tools(response_text):
    """解析响应文本，提取所有tool中的id和amount"""
    results = []

    # 匹配所有Response块中的tool部分
    tool_blocks = re.findall(r"'tool':\s*\{(.*?)\}", response_text, re.DOTALL)

    for block in tool_blocks:
        # 匹配id和amount对
        match = re.search(r"'id':\s*(\d+),\s*'amount':\s*(\d+)", block)
        if match:
            tool_id = int(match.group(1))
            amount = int(match.group(2))
            results.append([tool_id, amount])

    return results

