# 通过返回文本查找副本完成度
def look_fuben_integral(user_plant_data):
    if user_plant_data not in "跳过":
        match = re.search(r'<Response status=/onResult>(.*?)</Response>', user_plant_data, re.DOTALL)
        if match:
            # 提取出Response标签内的字符串
            response_str = match.group(1)

            # 将字符串安全地转换为字典
            response_dict = ast.literal_eval(response_str)

            # 查看副本完成度
            integral_number = int(response_dict['_integral'])

            return str(integral_number)

        else:
            return "跳过"

    else:
        return "跳过"

