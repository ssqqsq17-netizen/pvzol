# 数字格式转换
def num_format(num):
    if 1000000000000 > int(num) >= 100000000:
        return str(round(float(num) / 100000000, 2)) + "亿"

    if int(num) >= 1000000000000:
        # 将数字转换为科学计数法，保留两位小数
        scientific_notation = "{:.2e}".format(float(num))

        # 提取科学计数法中的系数和指数
        coefficient, exponent = scientific_notation.split('e')
        exponent = int(exponent)

        # 将指数转换为“亿”单位
        # 1亿 = 10^8，所以指数需要减去8
        exponent_in_billion = exponent - 8

        # 将指数转换为上标格式
        superscript_map = str.maketrans("0123456789", "⁰¹²³⁴⁵⁶⁷⁸⁹")
        exponent_superscript = str(exponent_in_billion).translate(superscript_map)

        # 返回格式化后的字符串
        return f"{coefficient}×10{exponent_superscript}亿"

    else:
        return str(num)

