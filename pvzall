backoff_count = 0
backoff_last_time = 0

def get_backoff_time():
    global backoff_count, backoff_last_time
    current_time = time.time()
    if current_time - backoff_last_time > 60:
        backoff_count = 0
    wait_time = min(14 * (2 ** backoff_count), 300)
    backoff_count += 1
    backoff_last_time = current_time
    return wait_time

def parse_jsonp(jsonp_text):
    """解析JSONP响应，提取JSON内容"""
    try:
        # 去除JSONP包装（通常是 jsonp123(...) 或 jsonp123(...)）
        start = jsonp_text.find('(')
        end = jsonp_text.rfind(')')
        if start != -1 and end != -1 and end > start:
            json_text = jsonp_text[start+1:end]
            return json.loads(json_text)
        return json.loads(jsonp_text)
    except:
        return jsonp_text

# 全局请求频率控制
last_request_time = 0
min_request_interval = 2.0  # 最小请求间隔（秒），增加到2秒
max_random_delay = 1.5  # 最大随机延迟（秒）

def wait_for_rate_limit():
    """确保请求之间有足够的间隔，并添加随机延迟模拟真实浏览器"""
    global last_request_time
    current_time = time.time()
    elapsed = current_time - last_request_time
    
    # 计算需要等待的时间（最小间隔 + 随机延迟）
    base_wait = max(0, min_request_interval - elapsed)
    random_wait = random.uniform(0, max_random_delay)
    total_wait = base_wait + random_wait
    
    if total_wait > 0:
        time.sleep(total_wait)
    
    last_request_time = time.time()

