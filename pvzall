def wait_until_next_run():
    # 获取当前时间
    now = datetime.now()
    # 计算今天凌晨4点的时间
    today_4am = datetime(now.year, now.month, now.day, 4, 0, 0)

    # 如果当前时间已经过了今天凌晨4点，则计算明天凌晨4点的时间
    if now > today_4am:
        today_4am += timedelta(days=1)

    # 计算等待时间（秒）
    wait_seconds = (today_4am - now).total_seconds()
    print(f"等待 {wait_seconds} 秒直到下一次运行...")
    time.sleep(wait_seconds)

