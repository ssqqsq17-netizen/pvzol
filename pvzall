def up_quality_pack(daqu, ck, plant_ids, log_sign):
    quality_map = {
        '劣质': 1,
        '普通': 2,
        '优秀': 3,
        '精良': 4,
        '极品': 5,
        '史诗': 6,
        '传说': 7,
        '神器': 8,
        '魔王': 9,
        '战神': 10,
        '至尊': 11,
        '魔神': 12,
        '耀世': 13,
        '不朽': 14,
        '永恒': 15,
        '太上': 16,
        '混沌': 17,
        '无极': 18
    }

    return_req = AMF_POST_new_bodys(plant_ids, 1, ck, daqu)
    
    # 提取每个植物的最高品质，返回字典 {plant_id: max_quality}
    plant_quality_dict = {}
    
    # 匹配所有Response块
    response_pattern = r"<Response status=/onResult>(\{.*?\})</Response>"
    response_matches = re.findall(response_pattern, str(return_req), re.DOTALL)
    
    # 遍历plant_ids和响应，记录每个植物的品质
    for i, match in enumerate(response_matches):
        if i < len(plant_ids):
            plant_id = plant_ids[i][0]
            try:
                # 转换为字典
                resp_dict = ast.literal_eval(match)
                # 提取品质信息（根据实际返回格式调整）
                quality_name = None
                if 'quality' in resp_dict:
                    quality_name = str(resp_dict['quality'])
                elif isinstance(resp_dict, list) and len(resp_dict) > 1:
                    # 如果是列表格式，尝试第二个元素作为品质（参考user_qualityUp返回格式）
                    quality_name = str(resp_dict[1])
                else:
                    # 尝试从字符串中匹配已知的品质名称
                    for q_name in quality_map.keys():
                        if q_name in match:
                            quality_name = q_name
                            break
                
                if quality_name:
                    # 更新该植物的最高品质
                    if plant_id not in plant_quality_dict:
                        plant_quality_dict[plant_id] = quality_name
                    else:
                        current_value = quality_map.get(plant_quality_dict[plant_id], 0)
                        new_value = quality_map.get(quality_name, 0)
                        if new_value > current_value:
                            plant_quality_dict[plant_id] = quality_name
            except:
                continue
    
    return plant_quality_dict

