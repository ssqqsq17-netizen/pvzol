def user_reward_list(daqu, ck, log_text):

    AMF_POST_LIST = [[]]
    AMF_POST_API = 'api.duty.getAll'

    return_req = AMF_POST(AMF_POST_LIST, AMF_POST_API, 0, ck, daqu)

    if "mainTask" in return_req:

        match = re.search(r'<Response status=/onResult>(.*?)</Response>', return_req, re.DOTALL)
        if match:
            # 提取出Response标签内的字符串
            response_str = match.group(1)

            # 将字符串安全地转换为字典
            response_dict = ast.literal_eval(response_str)

            tasks = response_dict['mainTask'] + response_dict['sideTask']
            result = [[task['id'], task['state']] for task in tasks]

            return result
    else:

        pr(f"出错了，加微信：QAQQJQ解决", log_text)
        return "跳过"

