# 取文本中间
def Text_Center(Original_text, left_text, right_text):
    temp_str = Original_text[Original_text.rfind(left_text):Original_text.rfind(right_text)]
    temp_str = temp_str.replace(left_text, '')
    return temp_str

# 取文本右边
def Find_Target(text, target):
    index = text.find(target)  # 找到目标字符串的起始位置
    if index != -1:
        result = text[index + len(target):]  # 取出目标字符串右边的内容
        return result
    else:
        return "目标字符串未找到"

