    while True:
        url = 'http://s' + str(daqu) + '.youkia.pvz.youkia.com/pvz/index.php/Warehouse/index/sig'

        # 获取用户仓库信息
        Warehouse_data = GET_TXT(url, daqu, ck)

        if Warehouse_data == "跳过":
            print('出错了，可能是丢包，暂停操作13秒')
            time.sleep(13)

        else:
            break

    Warehouse_data = Warehouse_data[1]

    # 解析XML字符串
    root = ET.fromstring(Warehouse_data)

    # 找到<warehouse>标签
    warehouse = root.find('warehouse')

    # 检查<warehouse>标签是否存在
    if warehouse is not None:
        # 提取tool_grid_amount和organism_grid_amount属性的值
        tool_grid_amount = warehouse.get('tool_grid_amount')
        organism_grid_amount = warehouse.get('organism_grid_amount')

    # 查找所有的 item 标签（递归查找）
    items = root.findall('.//item')

    # 初始化计数器
    count = 0

    # 遍历所有 item 标签
    for item in items:
        if 'qu' in item.attrib:
            count += 1

    return [tool_grid_amount, organism_grid_amount, count]

