# 添加小尾巴
def add_text_tail(text, tail="（小尾巴）", probability=0.005):
    """
    以指定的概率为文本添加小尾巴
    :param text: 原始文本
    :param tail: 小尾巴文本，默认为“（小尾巴）”
    :param probability: 添加小尾巴的概率，默认为0.01（百分之一）
    :return: 添加小尾巴后的文本或原始文本
    """
    # 使用闭包来模拟静态变量
    if not hasattr(add_text_tail, "counter"):
        add_text_tail.counter = 0  # 初始化计数器
    if not hasattr(add_text_tail, "threshold"):
        add_text_tail.threshold = int(1 / probability)  # 计算阈值

    add_text_tail.counter += 1  # 每次调用时计数器加1
    if add_text_tail.counter % add_text_tail.threshold == 0:  # 如果计数器达到阈值，则添加小尾巴
        return text + tail
    else:
        return text

