        # 如果该区间内没有任何任务编号，将整个区间添加到结果
        if not found:
            receivable_tasks.extend(range(start, end + 1))

    return receivable_tasks

def parse_response_text(response_text, task_id_list):
    """解析响应文本，提取列表位置对应的值和状态"""
    results = []

    # 匹配所有Envelope块
    envelopes = re.findall(r'<Envelope.*?<\/Envelope>', response_text, re.DOTALL)

    for envelope in envelopes:
        # 任务匹配正则表达式
        tasks = re.findall(r"\('\/(\d+)',\s*<Response\s+status=\/on\w+>(.*?)<\/Response>",
                           envelope, re.DOTALL)

        for task_id, status_content in tasks:
            try:
                # 将任务ID转换为整数
                task_id = int(task_id)

                # 计算列表索引（从0开始）
                list_index = task_id - 1

                # 获取列表位置对应的值
                list_value = task_id_list[list_index]

                # 处理不同类型的响应
                if "user_exp" in status_content:
                    # 提取onResult类型的状态
                    status = re.search(r"{'user_exp':\s*\d+,\s*'up_grade':\s*\[\]}", status_content)
                    results.append([list_value, "领取成功"])
                else:
                    # 提取onStatus类型的状态
                    desc = re.search(r"description='(.*?)'", status_content)
                    results.append([list_value, desc.group(1) if desc else "未知状态"])
            except IndexError:
                # 处理列表索引越界的情况
                results.append([task_id, f"未知任务ID: {task_id}"])

    return results

# 解析副本获得道具
def parse_fuben_item(user_plant_data):

    """解析响应文本，提取所有tools中的tool_id和amount"""
    results = []

    # 匹配所有Response块中的tools部分
    tools_blocks = re.findall(r"'tools':\s*\[(.*?)\]", user_plant_data, re.DOTALL)

    for block in tools_blocks:
        # 匹配每个tool_id和amount对
        tools = re.findall(r"'tool_id':\s*(\d+),\s*'amount':\s*'(\d+)'", block)

        for tool_id, amount in tools:
            results.append([int(tool_id), int(amount)])

    return results

